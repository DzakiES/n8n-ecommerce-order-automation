        "jsCode": "const rows = $input.all();\n\nconst pendingOrders = rows.filter(row => \n  row.json.Status === \"New\"\n);\n\nif (pendingOrders.length === 0) {\n  return [{ json: { hasPending: false, orders: [] } }];\n}\n\nreturn [{\n  json: {\n    hasPending: true,\n    count: pendingOrders.length,\n    orders: pendingOrders.map(row => ({\n      order_id: row.json['Order ID'],\n      customer_name: row.json['Customer Name'],\n      product: row.json['Product'],\n      quantity: row.json['Quantity'],\n      order_total: row.json['Order Total'],\n      date: row.json['Date']\n    }))\n  }\n}];"
      },
