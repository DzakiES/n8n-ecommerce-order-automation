    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Classification logic\nlet category;\nif (body.quantity < 100) {\n  category = \"STANDARD\";\n} else if (body.quantity <= 500) {\n  category = \"BULK\";\n} else {\n  category = \"VIP\";\n}\n\nreturn [{\n  json: {\n    order_id: body.order_id,\n    customer_name: body.customer_name,\n    customer_email: body.customer_email,\n    product: body.product,\n    quantity: body.quantity,\n    price_per_item: body.price_per_item,\n    order_total: body.order_total,\n    shipping_address: body.shipping_address,\n    order_date: body.order_date,\n    category: category\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        16,
        -80
      ],
      "id": "7cd74eee-0baf-4257-bde3-089907ab1e28",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a customer service assistant for an online shop.\n\nWrite a short thank-you email body based on the order category:\n- STANDARD: warm and friendly (3 sentences)\n- BULK: friendly + mention 10% discount on next order (3-4 sentences)\n- VIP: sophisticated and personal, mention priority handling (4-5 sentences)\n\nOrder details:\n- Customer name: {{ $json.customer_name }}\n- Product: {{ $json.product }}\n- Quantity: {{ $json.quantity }}\n- Order total: ${{ $json.order_total }}\n- Order ID: {{ $json.order_id }}\n- Category: {{ $json.category }}\n\nJust write the email body. No subject line. No sign-off name.",
        "options": {}
      },
